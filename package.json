{
	"name": "awilix-modular",
	"description": "HTTP-framework-agnostic modular DI and CQRS framework for Awilix with Nest-like module patterns and strict type safety",
	"main": "dist/index.js",
	"types": "dist/index.d.ts",
	"version": "2.2.1",
	"license": "MIT",
	"scripts": {
		"build": "tsc",
		"build:watch": "tsc --watch",
		"build:release": "del-cli dist && npm run lint && npm run build",
		"check-types": "tsc --pretty --noEmit",
		"lint:fix": "biome check --write lib test index.ts",
		"lint": "biome check lib test",
		"test": "vitest run",
		"test:watch": "vitest",
		"test:coverage": "vitest run --coverage",
		"test:types": "tstyche",
		"test:types:watch": "tstyche --watch"
	},
	"peerDependencies": {
		"awilix": ">=9.0.0"
	},
	"devDependencies": {
		"@biomejs/biome": "2.3.15",
		"@types/node": "^22.15.21",
		"@vitest/coverage-v8": "^4.0.18",
		"del-cli": "^7.0.0",
		"tstyche": "^5.0.2",
		"typescript": "^5.9.3",
		"vitest": "^4.0.18"
	},
	"type": "module",
	"repository": {
		"type": "git",
		"url": "git://github.com/wildstyles/awilix-modular.git"
	},
	"keywords": [
		"modular",
		"dependency-injection",
		"di",
		"modularization",
		"awilix",
		"cqrs",
		"mediator"
	],
	"homepage": "https://github.com/wildstyles/awilix-modular",
	"files": [
		"README.md",
		"LICENSE",
		"dist/*"
	]
}
